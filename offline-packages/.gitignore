# GNU Emacs source tarballs — large, downloadable on demand via fetch-source.sh
sources/*.tar.xz
sources/*.tar.gz

# Local/vendored packages — contents vary per machine, may be their own repos
local-packages/*
!local-packages/.gitkeep

# Docs drop-zone — e.g. cloned reference repos like setting-up-emacs-for-coding
docs/*
!docs/.gitkeep

# Offline Windows tool bundles — pre-downloaded artifacts, large (~900 MB)
windows-tools-offline-*.tar.gz

# Non-Emacs tools drop-zone — language-server / debugger binaries per platform
tools/*
!tools/.gitkeep
!tools/README.md
!tools/setup-windows-tools.bat
!tools/prep-windows-offline.sh
